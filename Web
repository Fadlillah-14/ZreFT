// ── State ──
const MODS = [...new Set(BANK.map(q => q.mod))];
let selMods = new Set(MODS);
let qCount = 10;
let examMode = false;
let questions = [];
let idx = 0;
let answers = []; // null | { chosen: [] | int, correct: bool, skipped: bool }
let multiChosen = [];
let timerInt = null;
let timeLeft = 3600;

// ── Build module cards ──
const modGrid = document.getElementById('modGrid');
MODS.forEach((m, i) => {
  const n = BANK.filter(q => q.mod === m).length;
  const d = document.createElement('div');
  d.className = 'mod-card sel';
  d.dataset.m = m;
  const short = m.split('–')[1]?.trim() || m;
  d.innerHTML = `<div class="mod-n">M${i+1}</div><div class="mod-t">${short}</div><div class="mod-c">${n} questions</div>`;
  d.onclick = () => {
    if (selMods.has(m)) { if (selMods.size === 1) return; selMods.delete(m); d.classList.remove('sel'); }
    else { selMods.add(m); d.classList.add('sel'); }
  };
  modGrid.appendChild(d);
});

// ── N buttons ──
document.querySelectorAll('#nRow .opt-btn').forEach(b => {
  b.onclick = () => {
    document.querySelectorAll('#nRow .opt-btn').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    const v = b.dataset.n;
    qCount = v === 'all' ? 9999 : parseInt(v);
    examMode = (v === '25');
    document.getElementById('timerNote').textContent = examMode
      ? '⏱ 60-minute timer will activate.'
      : 'Timer activates in 25-question exam mode.';
  };
});

function shuffle(a) {
  const r = [...a];
  for (let i = r.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i+1)); [r[i],r[j]] = [r[j],r[i]]; }
  return r;
}

function startQuiz() {
  const pool = BANK.filter(q => selMods.has(q.mod));
  questions = shuffle(pool).slice(0, Math.min(qCount, pool.length));
  answers = new Array(questions.length).fill(null);
  idx = 0;
  multiChosen = [];
  showScreen('sQuiz');
  renderQ();
  if (examMode) {
    timeLeft = 3600;
    const td = document.getElementById('hTimer');
    td.style.display = 'block';
    td.classList.remove('warn');
    timerInt = setInterval(() => {
      timeLeft--;
      const m = String(Math.floor(timeLeft/60)).padStart(2,'0');
      const s = String(timeLeft%60).padStart(2,'0');
      td.textContent = `${m}:${s}`;
      if (timeLeft <= 300) td.classList.add('warn');
      if (timeLeft <= 0) { clearInterval(timerInt); showResult(); }
    }, 1000);
  }
}

function renderQ() {
  const q = questions[idx];
  const total = questions.length;
  multiChosen = [];

  document.getElementById('progFill').style.width = `${(idx/total)*100}%`;
  document.getElementById('qNum').textContent = `${idx+1} / ${total}`;

  // Tags
  const tagRow = document.getElementById('tagRow');
  tagRow.innerHTML = `<span class="tag tag-mod">${q.mod}</span>`;
  if (q.type === 'multi') tagRow.innerHTML += `<span class="tag tag-multi">Multiple Answer</span>`;
  if (q.type === 'tf') tagRow.innerHTML += `<span class="tag tag-tf">True / False</span>`;

  document.getElementById('qText').textContent = q.q;
  document.getElementById('multiHint').style.display = q.type === 'multi' ? 'flex' : 'none';
  document.getElementById('expBox').className = 'exp-box';
  document.getElementById('expBox').innerHTML = '';
  document.getElementById('btnNext').style.display = 'none';
  document.getElementById('multiSubmit').className = 'multi-submit' + (q.type === 'multi' ? ' show' : '');

  const labels = ['A','B','C','D','E','F'];
  const optsEl = document.getElementById('opts');
  optsEl.innerHTML = '';

  q.opts.forEach((o, i) => {
    const btn = document.createElement('button');
    btn.className = 'opt';
    if (q.type === 'multi') {
      btn.innerHTML = `<span class="opt-cb"></span><span>${o}</span>`;
      btn.onclick = () => toggleMulti(i, btn);
    } else {
      btn.innerHTML = `<span class="opt-lbl">${labels[i]}</span><span>${o}</span>`;
      btn.onclick = () => selectSingle(i);
    }
    optsEl.appendChild(btn);
  });
}

function toggleMulti(i, btn) {
  if (btn.disabled) return;
  if (multiChosen.includes(i)) {
    multiChosen = multiChosen.filter(x => x !== i);
    btn.classList.remove('checked');
    btn.querySelector('.opt-cb').textContent = '';
  } else {
    multiChosen.push(i);
    btn.classList.add('checked');
    btn.querySelector('.opt-cb').textContent = '✓';
  }
}

function submitMulti() {
  const q = questions[idx];
  const correct = q.correct; // array
  const chosen = [...multiChosen].sort();
  const exp = [...correct].sort();
  const isCorrect = JSON.stringify(chosen) === JSON.stringify(exp);

  answers[idx] = { chosen, correct: isCorrect, skipped: false, type: 'multi', correctIdxs: correct };

  const btns = document.querySelectorAll('.opt');
  btns.forEach(b => { b.disabled = true; });

  btns.forEach((btn, i) => {
    const inChosen = chosen.includes(i);
    const inCorrect = correct.includes(i);
    if (inCorrect) btn.classList.add('correct');
    else if (inChosen && !inCorrect) btn.classList.add('wrong');
  });

  showExplanation(q.exp);
  document.getElementById('multiSubmit').style.display = 'none';
  showNextBtn();
}

function selectSingle(i) {
  const q = questions[idx];
  const isCorrect = i === q.correct;
  answers[idx] = { chosen: i, correct: isCorrect, skipped: false, type: q.type };

  const btns = document.querySelectorAll('.opt');
  btns.forEach(b => { b.disabled = true; });
  btns[q.correct].classList.add('correct');
  if (!isCorrect) btns[i].classList.add('wrong');

  showExplanation(q.exp);
  showNextBtn();
}

function showExplanation(text) {
  const box = document.getElementById('expBox');
  box.innerHTML = `<strong>Explanation:</strong> ${text}`;
  box.classList.add('show');
}

function showNextBtn() {
  const btn = document.getElementById('btnNext');
  btn.style.display = 'inline-block';
  btn.textContent = idx === questions.length - 1 ? 'View Results →' : 'Next →';
}

function skipQ() {
  answers[idx] = { chosen: null, correct: false, skipped: true };
  nextQ();
}

function nextQ() {
  if (idx >= questions.length - 1) showResult();
  else { idx++; renderQ(); }
}

function showResult() {
  clearInterval(timerInt);
  document.getElementById('hTimer').style.display = 'none';

  let ok = 0, no = 0, sk = 0;
  answers.forEach(a => {
    if (!a || a.skipped) sk++;
    else if (a.correct) ok++;
    else no++;
  });

  const total = questions.length;
  const pct = Math.round((ok / total) * 100);

  document.getElementById('resPct').textContent = pct + '%';
  document.getElementById('stOk').textContent = ok;
  document.getElementById('stNo').textContent = no;
  document.getElementById('stSk').textContent = sk;

  const v = document.getElementById('resVerdict');
  const s = document.getElementById('resSub');
  if (pct >= 60) {
    v.textContent = '✅ PASSED'; v.className = 'res-verdict pass';
    s.textContent = pct >= 75 ? 'Excellent! You meet the Trainer/Consultant requirement (≥75%).' : 'Congratulations! You passed the 60% passing grade.';
  } else {
    v.textContent = '❌ Not Passed Yet'; v.className = 'res-verdict fail';
    s.textContent = 'MTCNA passing grade is 60%. Keep practicing!';
  }

  // Ring animation
  const circ = 339.3;
  const offset = circ - (pct / 100) * circ;
  const arc = document.getElementById('ringArc');
  arc.style.stroke = pct >= 60 ? '#238636' : '#da3633';
  setTimeout(() => { arc.style.strokeDashoffset = offset; }, 100);

  // Review
  const box = document.getElementById('reviewBox');
  box.innerHTML = '';
  const labels = ['A','B','C','D','E','F'];
  questions.forEach((q, i) => {
    const a = answers[i];
    const div = document.createElement('div');
    let cls = 'ri ri-skip', ansHtml = '';

    if (!a || a.skipped) {
      cls = 'ri ri-skip';
      if (q.type === 'multi') {
        const cLabels = q.correct.map(x => labels[x] + '. ' + q.opts[x]).join(', ');
        ansHtml = `<span class="no">Skipped</span> · <span class="ok">Correct: ${cLabels}</span>`;
      } else {
        ansHtml = `<span class="no">Skipped</span> · <span class="ok">Correct: ${labels[q.correct]}. ${q.opts[q.correct]}</span>`;
      }
    } else if (a.correct) {
      cls = 'ri ri-ok';
      if (q.type === 'multi') {
        ansHtml = `<span class="ok">✓ ${a.chosen.map(x => labels[x]).join(', ')} — All correct</span>`;
      } else {
        ansHtml = `<span class="ok">✓ ${labels[a.chosen]}. ${q.opts[a.chosen]}</span>`;
      }
    } else {
      cls = 'ri ri-no';
      if (q.type === 'multi') {
        const cLabels = q.correct.map(x => labels[x] + '. ' + q.opts[x]).join(', ');
        const yLabels = a.chosen.length ? a.chosen.map(x => labels[x]).join(', ') : '(none)';
        ansHtml = `<span class="no">✗ Your: ${yLabels}</span> · <span class="ok">Correct: ${cLabels}</span>`;
      } else {
        ansHtml = `<span class="no">✗ ${labels[a.chosen]}. ${q.opts[a.chosen]}</span> · <span class="ok">Correct: ${labels[q.correct]}. ${q.opts[q.correct]}</span>`;
      }
    }

    div.className = cls;
    div.innerHTML = `<div class="rq">${i+1}. ${q.q}</div><div class="ra">${ansHtml}</div>`;
    box.appendChild(div);
  });

  showScreen('sResult');
}

function retryQuiz() { startQuiz(); }
function goHome() {
  clearInterval(timerInt);
  document.getElementById('hTimer').style.display = 'none';
  document.getElementById('hTimer').classList.remove('warn');
  showScreen('sStart');
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}
</script>
</body>
</html>
